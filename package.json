{
  "name": "policychecks",
  "version": "0.5.1",
  "description": "A badge service for reporting selected GitHub repository administration settings from direct API evidence",
  "private": true,
  "type": "module",
  "main": "dist/app.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx src/app.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run typecheck && npm test",
    "check-updates": "if [ \"$CI\" = \"true\" ]; then echo 'Skipping dependency update notifier in CI.'; else npx npm-check-updates --enginesNode; fi",
    "check-updates:update": "npx npm-check-updates --enginesNode -u",
    "deploy": "wrangler deploy -c wrangler.policychecks.jsonc",
    "deploy:preview": "wrangler versions upload -c wrangler.policychecks.jsonc",
    "deploy:policychecks": "wrangler deploy -c wrangler.policychecks.jsonc",
    "prepare": "husky"
  },
  "keywords": [
    "security",
    "repository-administration",
    "repository-settings",
    "badge",
    "supply-chain",
    "best-practices"
  ],
  "author": {
    "name": "Reponomics Contributors",
    "email": "policychecks@reponomics.org"
  },
  "license": "MIT",
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/request": "^10.0.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  }
}
