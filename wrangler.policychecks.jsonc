{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "policychecks",
  "main": "cloudflare/policychecks-worker.ts",
  "compatibility_date": "2026-05-31",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "policychecks.reponomics.org",
      "custom_domain": true
    }
  ]
}
